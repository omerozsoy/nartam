# nartam ortam yapılandırması.
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldurun. `.env` git'e dahil DEĞİLDİR.

# Sürücü: mysql (üretim) | sqlite (yerel geliştirme)
DB_DRIVER=mysql

# --- MySQL (Plesk'te oluşturduğunuz veritabanı bilgileri) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nartam
DB_USER=nartam_user
DB_PASS=degistirin

# --- SQLite kullanıyorsanız yukarıdakiler yok sayılır; dosya data/nartam.sqlite'a yazılır ---
